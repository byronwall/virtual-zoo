# Required for AI SDK calls to OpenAI.
OPENAI_API_KEY=your_openai_api_key_here

# App-level model defaults.
OPENAI_MODEL=gpt-5-mini
OPENAI_HEAVY_MODEL=gpt-5.4

# App URL used for Stripe redirects and magic links.
APP_BASE_URL=http://localhost:3000
PRODUCT_NAME=Starter

# Persistent server data directory. Docker Compose mounts a named volume here.
APP_DATA_DIR=app/data

# Site personalization. Missing or invalid values fall back to the current Violet/orange site.
SITE_TITLE="Violet's Stuffed Animal Zoo"
SITE_SHORT_TITLE="Violet's Zoo"
SITE_PRIMARY_COLOR=orange
SITE_ICON_VARIANT=default

# File-backed starter auth/admin.
EMAIL_DELIVERY=console
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM="Starter <support@example.com>"
SUPER_USER_EMAIL=owner@example.com

# Stripe credit-pack starter billing.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_CREDIT_PACK=price_your_credit_pack_price_here
CREDIT_PACK_CREDITS=10
CREDIT_PACK_AMOUNT_CENTS=1000
CREDIT_PACK_CURRENCY=usd
